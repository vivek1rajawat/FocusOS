PORT=5000
NODE_ENV=development
# Comma-separated list of allowed CORS origins, e.g.
# https://focus-os-omega.vercel.app,https://focus-os-git-main-vivek1rajawats-projects.vercel.app
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/focusos

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FocusOS <no-reply@focusos.app>
